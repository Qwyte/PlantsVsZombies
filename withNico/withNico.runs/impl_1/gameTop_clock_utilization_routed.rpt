# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y17 [get_cells myClock/inst/clkf_buf]
set_property LOC BUFGCTRL_X0Y16 [get_cells myClock/inst/clkout1_buf]
set_property LOC BUFGCTRL_X0Y0 [get_cells gameClk_reg_n_0_BUFG_inst]

# Location of IO Primitives which is load of clock spine

# Location of clock ports
set_property LOC IOB_X1Y126 [get_ports clk]

# Clock net "myClock/inst/clk_out1" driven by instance "myClock/inst/clkout1_buf" located at site "BUFGCTRL_X0Y16"
#startgroup
create_pblock {CLKAG_myClock/inst/clk_out1}
add_cells_to_pblock [get_pblocks  {CLKAG_myClock/inst/clk_out1}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="myClock/inst/clk_out1"}]]]
resize_pblock [get_pblocks {CLKAG_myClock/inst/clk_out1}] -add {CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "gameClk_reg_n_0_BUFG" driven by instance "gameClk_reg_n_0_BUFG_inst" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_gameClk_reg_n_0_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_gameClk_reg_n_0_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="gameClk_reg_n_0_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_gameClk_reg_n_0_BUFG}] -add {CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup
